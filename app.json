{
  "expo": {
    "name": "CK",
    "slug": "ck-calorie-counter",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Logo.png",
    "scheme": "mynewapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.avcheban1988.ckcaloriecounter",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#53B175",
        "foregroundImage": "./assets/images/Logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.avcheban1988.ckcaloriecounter"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#53B175",
          "dark": {
            "backgroundColor": "#53B175"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "apiUrl": "https://getthisjob.ru",
      "appDisplayName": "CK - счетчик калорий",
      "router": {},
      "eas": {
        "projectId": "00ace23d-da74-4d08-9eed-bf15e02236e2"
      }
    }
  }
}
